# SiliconFlow OpenAI 兼容接口（https://api.siliconflow.cn）
# 在控制台复制 API Key 后填入，并重命名为 .env.local 使用（勿提交仓库）

SILICONFLOW_API_KEY=

# 可选，默认 https://api.siliconflow.cn/v1
# SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# 可选，默认 DeepSeek V3（SiliconFlow 模型 ID）
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# 可选：情绪评估专用模型（默认与 SILICONFLOW_MODEL 相同）
# SILICONFLOW_EMOTION_MODEL=deepseek-ai/DeepSeek-V3
